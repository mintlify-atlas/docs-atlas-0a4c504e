  "keyFeatures": [
    "AI-powered code assistance with multiple provider support (Claude, OpenAI, Gemini, Copilot, etc.)",
    "Agentic mode with autonomous tool execution and code generation",
    "Fast Apply for instant code edits with specialized models",
    "Zen Mode for terminal-based Vibe Coding experience",
    "Agent Client Protocol (ACP) support for standardized agent communication",
    "Project-specific instruction files (avante.md) for context-aware assistance",
    "RAG service integration for project-aware code suggestions",
    "Inline code suggestions and diff management",
    "Extensive customization with keybindings, windows, and behavior options",
    "Integration with completion frameworks (nvim-cmp, blink.cmp)"
  ],
  "publicApiSurface": [
    ":AvanteAsk - Ask AI about code with optional positioning",
    ":AvanteChat - Start chat session with codebase",
    ":AvanteChatNew - Create new chat session",
    ":AvanteEdit - Edit selected code blocks",
    ":AvanteToggle - Toggle AI sidebar",
    ":AvanteFocus - Switch focus to/from sidebar",
    ":AvanteRefresh - Refresh all windows",
    ":AvanteStop - Stop current AI request",
    ":AvanteSwitchProvider - Switch AI provider",
    ":AvanteShowRepoMap - Show project structure map",
    ":AvanteModels - Show available models",
    ":AvanteHistory - Open chat history picker",
    ":AvanteClear - Clear chat history or cache",
    ":AvanteBuild - Build plugin dependencies",
    "require('avante').setup() - Plugin setup function",
    "require('avante.api').ask() - Programmatic ask",
    "require('avante.api').edit() - Programmatic edit",
    "require('avante.api').zen_mode() - Enter Zen Mode",
    "require('avante').toggle() - Toggle sidebar programmatically"
  ]
}
